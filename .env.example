# ─── Database ──────────────────────────────────────────────
DATABASE_URL=postgresql://financepulse:changeme@localhost:5432/financepulse
POSTGRES_USER=financepulse
POSTGRES_PASSWORD=changeme
POSTGRES_DB=financepulse

# ─── Redis ─────────────────────────────────────────────────
REDIS_URL=redis://redis:6379

# ─── JWT Authentication ───────────────────────────────────
# Generate with: openssl rand -base64 64
JWT_SECRET=change-me-to-a-random-secret
JWT_REFRESH_SECRET=change-me-to-another-random-secret

# ─── Finnhub (Stocks — WebSocket + REST) ─────────────────
# Free tier at https://finnhub.io — up to 50 WebSocket symbols
FINNHUB_API_KEY=

# ─── Alpha Vantage (Historical Data — optional fallback) ──
# Free tier: 25 requests/day — https://www.alphavantage.co/support/#api-key
ALPHA_VANTAGE_KEY=

# ─── Backend Server ──────────────────────────────────────
RUST_LOG=info

# ─── CORS ───────────────────────────────────────────────
# Comma-separated list of allowed origins for CORS
ALLOWED_ORIGINS=https://financepulse.xyz,http://localhost:3003

# ─── Frontend URLs ────────────────────────────────────────
# For local dev:
NEXT_PUBLIC_API_URL=http://localhost:8080
NEXT_PUBLIC_WS_URL=ws://localhost:8080/ws
# For production (set in docker-compose.yml build args):
# NEXT_PUBLIC_API_URL=https://financepulse.xyz/api
# NEXT_PUBLIC_WS_URL=wss://financepulse.xyz/ws
