FROM rust:1.82-bookworm

WORKDIR /app

# Install cargo-watch for hot reload and sqlx-cli for migrations
RUN cargo install cargo-watch sqlx-cli --no-default-features --features rustls,postgres

# Copy manifests and build dependencies first (layer cache)
COPY Cargo.toml Cargo.lock ./
RUN mkdir src && echo "fn main() {}" > src/main.rs
RUN cargo build
RUN rm -rf src

# Source code is mounted as a volume at runtime
COPY src/ src/
COPY migrations/ migrations/

ENV SQLX_OFFLINE=true

EXPOSE 8080

CMD ["cargo", "watch", "-x", "run"]
